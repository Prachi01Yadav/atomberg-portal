# ── App ──────────────────────────────────────────────────
APP_NAME=AtomQuest Goal Portal
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ORIGINS=http://localhost:5173,http://localhost:80

# ── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://atomquest:atomquest@postgres:5432/atomquest
POSTGRES_USER=atomquest
POSTGRES_PASSWORD=atomquest
POSTGRES_DB=atomquest

# ── Redis ────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── JWT ──────────────────────────────────────────────────
JWT_ALGORITHM=HS256

# ── Anthropic AI ─────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
AI_CACHE_TTL_SECONDS=3600

# ── Blockchain (Polygon Amoy) ──────────────────────────────
BLOCKCHAIN_MODE=mock
POLYGON_RPC_URL=https://rpc-amoy.polygon.technology/
POLYGON_CONTRACT_ADDRESS=
POLYGON_PRIVATE_KEY=
POLYGON_SCAN_BASE_URL=https://amoy.polygonscan.com/tx/

# ── Email (FastAPI-Mail) ─────────────────────────────────
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@atomquest.demo
MAIL_PORT=587
MAIL_SERVER=smtp.sendgrid.net
MAIL_STARTTLS=true
MAIL_SSL_TLS=false
MAIL_FROM_NAME=AtomQuest

# ── Microsoft Teams ──────────────────────────────────────
TEAMS_WEBHOOK_URL=

# ── Azure AD / Entra (optional SSO) ────────────────────────
SSO_MODE=mock   # mock | live
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=
AZURE_REDIRECT_URI=http://localhost:5173/auth/callback
# Optional: map Entra ID group object IDs to roles (live SSO only)
AZURE_ADMIN_GROUP_ID=
AZURE_MANAGER_GROUP_ID=
AZURE_EMPLOYEE_GROUP_ID=

# Deep links in email / Teams cards (match your Vite port)
APP_BASE_URL=http://localhost:5174
